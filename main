# ==================== 第一部分：导入依赖库 ====================
import sys
from PyQt5.QtCore import *
from PyQt5.QtGui import *
from PyQt5.QtWidgets import *
from datetime import datetime, date, timedelta
import json
import os
from houtai_test import register_user, login_user, get_user_info


# ==================== 第二部分：登录注册对话框类 ====================
class LoginDialog(QDialog):
    """
    登录注册对话框类
    功能：提供用户登录和注册界面，验证用户身份
    继承自：QDialog（模态对话框）
    """

    def __init__(self):
        """初始化登录对话框"""
        super().__init__()
        self.setWindowTitle("用户登录 - 编程学习系统")
        self.setFixedSize(450, 380)
        self.setModal(True)

        # 定义配色方案 - 自然色系
        self.NATURE_RED = "#C85A54"
        self.NATURE_CYAN = "#4DBBD5"
        self.NATURE_GREEN = "#00A087"
        self.NATURE_BLUE = "#3C5488"
        self.NATURE_ORANGE = "#D4906B"
        self.BG_LIGHT = "#E0F6FF"
        self.TEXT_PRIMARY = "#1a3a52"

        # 用户信息变量
        self.user_id = None
        self.username = None

        self.initUI()

    def initUI(self):
        """初始化用户界面 - 创建登录表单和按钮"""
        layout = QVBoxLayout(self)
        layout.setSpacing(15)
        layout.setContentsMargins(30, 30, 30, 30)

        # --- 标题区域 ---
        title_label = QLabel("🎓 编程学习系统")
        title_label.setFont(QFont("Microsoft YaHei", 18, QFont.Bold))
        title_label.setAlignment(Qt.AlignCenter)
        title_label.setStyleSheet(f"""
            QLabel {{
                color: {self.NATURE_BLUE};
                padding: 10px;
            }}
        """)
        layout.addWidget(title_label)

        subtitle_label = QLabel("请登录您的账号")
        subtitle_label.setFont(QFont("Microsoft YaHei", 11))
        subtitle_label.setAlignment(Qt.AlignCenter)
        subtitle_label.setStyleSheet(f"color: {self.TEXT_PRIMARY};")
        layout.addWidget(subtitle_label)

        # --- 表单区域 ---
        form_widget = QWidget()
        form_layout = QVBoxLayout(form_widget)
        form_layout.setSpacing(12)

        # 用户名输入框
        username_label = QLabel("用户名:")
        username_label.setFont(QFont("Microsoft YaHei", 10))
        username_label.setStyleSheet(f"color: {self.TEXT_PRIMARY};")
        form_layout.addWidget(username_label)

        self.username_input = QLineEdit()
        self.username_input.setFont(QFont("Microsoft YaHei", 11))
        self.username_input.setPlaceholderText("请输入用户名")
        self.username_input.setStyleSheet(f"""
            QLineEdit {{
                padding: 10px;
                border: 2px solid {self.NATURE_CYAN};
                border-radius: 6px;
                background-color: {self.BG_LIGHT};
                color: {self.TEXT_PRIMARY};
            }}
            QLineEdit:focus {{
                border-color: {self.NATURE_BLUE};
            }}
        """)
        form_layout.addWidget(self.username_input)

        # 密码输入框
        password_label = QLabel("密码:")
        password_label.setFont(QFont("Microsoft YaHei", 10))
        password_label.setStyleSheet(f"color: {self.TEXT_PRIMARY};")
        form_layout.addWidget(password_label)

        self.password_input = QLineEdit()
        self.password_input.setFont(QFont("Microsoft YaHei", 11))
        self.password_input.setPlaceholderText("请输入密码")
        self.password_input.setEchoMode(QLineEdit.Password)
        self.password_input.setStyleSheet(f"""
            QLineEdit {{
                padding: 10px;
                border: 2px solid {self.NATURE_CYAN};
                border-radius: 6px;
                background-color: {self.BG_LIGHT};
                color: {self.TEXT_PRIMARY};
            }}
            QLineEdit:focus {{
                border-color: {self.NATURE_BLUE};
            }}
        """)
        self.password_input.returnPressed.connect(self.handle_login)
        form_layout.addWidget(self.password_input)

        layout.addWidget(form_widget)

        # --- 按钮区域 ---
        btn_layout = QHBoxLayout()
        btn_layout.setSpacing(10)

        self.login_btn = QPushButton("登录")
        self.register_btn = QPushButton("注册")

        for btn in [self.login_btn, self.register_btn]:
            btn.setFont(QFont("Microsoft YaHei", 11))
            btn.setFixedHeight(40)

        self.login_btn.setStyleSheet(f"""
            QPushButton {{
                background-color: {self.NATURE_GREEN};
                color: #FFFFFF;
                border: none;
                border-radius: 6px;
                font-weight: bold;
            }}
            QPushButton:hover {{
                background-color: #00C4A7;
            }}
        """)

        self.register_btn.setStyleSheet(f"""
            QPushButton {{
                background-color: {self.NATURE_ORANGE};
                color: #FFFFFF;
                border: none;
                border-radius: 6px;
                font-weight: bold;
            }}
            QPushButton:hover {{
                background-color: #E4A07B;
            }}
        """)

        self.login_btn.clicked.connect(self.handle_login)
        self.register_btn.clicked.connect(self.handle_register)

        btn_layout.addWidget(self.login_btn)
        btn_layout.addWidget(self.register_btn)

        layout.addLayout(btn_layout)

        # --- 提示信息 ---
        hint_label = QLabel("💡 提示：首次使用请点击\"注册\"按钮创建新账号\n默认测试账号: default_user / 123456")
        hint_label.setFont(QFont("Microsoft YaHei", 9))
        hint_label.setAlignment(Qt.AlignCenter)
        hint_label.setStyleSheet(f"color: {self.NATURE_BLUE}; padding: 5px;")
        hint_label.setWordWrap(True)
        layout.addWidget(hint_label)

        self.message_label = QLabel("")
        self.message_label.setFont(QFont("Microsoft YaHei", 9))
        self.message_label.setAlignment(Qt.AlignCenter)
        self.message_label.setStyleSheet("color: red; min-height: 20px;")
        layout.addWidget(self.message_label)

    def handle_login(self):
        """处理用户登录请求"""
        try:
            username = self.username_input.text().strip()
            password = self.password_input.text().strip()

            if not username or not password:
                self.message_label.setText("❌ 用户名和密码不能为空")
                return

            result = login_user(username, password)

            if result["success"]:
                self.user_id = result["user_id"]
                self.username = result["username"]
                self.accept()
            else:
                self.message_label.setText(f"❌ {result['message']}")
        except Exception as e:
            self.message_label.setText(f"❌ 登录异常: {str(e)}")
            print(f"登录错误详情: {e}")
            import traceback
            traceback.print_exc()

    def handle_register(self):
        """处理用户注册请求"""
        try:
            username = self.username_input.text().strip()
            password = self.password_input.text().strip()

            if not username or not password:
                self.message_label.setText("❌ 用户名和密码不能为空")
                return

            if len(username) < 3:
                self.message_label.setText("❌ 用户名长度至少3位")
                return

            if len(password) < 6:
                self.message_label.setText("❌ 密码长度至少6位")
                return

            result = register_user(username, password)

            if result["success"]:
                QMessageBox.information(self, "注册成功",
                                        f"✅ 注册成功！\n用户名: {username}\n\n即将自动登录")
                self.user_id = result["user_id"]
                self.username = username
                self.accept()
            else:
                self.message_label.setText(f"❌ {result['message']}")
        except Exception as e:
            self.message_label.setText(f"❌ 注册异常: {str(e)}")
            print(f"注册错误详情: {e}")
            import traceback
            traceback.print_exc()

    def get_user_info(self):
        """获取当前登录用户的信息"""
        return self.user_id, self.username


# ==================== 第三部分：主学习窗口类 ====================
class CodeLearnWindow(QMainWindow):
    """
    编程学习主窗口类
    功能：提供课程学习、打卡日历、货币系统等完整功能
    继承自：QMainWindow（主窗口）
    """

    def __init__(self, user_id=None, username=None):
        """
        初始化主窗口
        参数：
            user_id: 当前用户ID
            username: 当前用户名
        """
        super().__init__()
        self.current_user_id = user_id
        self.current_username = username
        self.setWindowTitle(f"编译语言学习软件 - C / Python 编程学习 | 用户: {username if username else '未登录'}")
        self.setMinimumSize(1400, 900)

        # 定义配色方案
        self.NATURE_RED = "#C85A54"
        self.NATURE_CYAN = "#4DBBD5"
        self.NATURE_GREEN = "#00A087"
        self.NATURE_BLUE = "#3C5488"
        self.NATURE_ORANGE = "#D4906B"
        self.NATURE_PURPLE = "#8491B4"

        self.BG_DARK = "#87CEEB"
        self.BG_MEDIUM = "#B0E0E6"
        self.BG_LIGHT = "#E0F6FF"
        self.TEXT_PRIMARY = "#1a3a52"
        self.TEXT_SECONDARY = "#2c5f7d"
        self.BORDER_COLOR = "#5FB8D9"

        # --- 数据文件路径 ---
        self.checkin_file = "checkin_data.json"
        self.checkin_data = self.load_checkin_data()

        self.currency_file = "currency_data.json"
        self.currency_data = self.load_currency_data()

        self.progress_file = "learning_progress.json"
        self.learning_progress = self.load_learning_progress()

        # 当前年月（用于日历显示）
        today = date.today()
        self._current_year = today.year
        self._current_month = today.month

        # 当前选中的课程和关卡
        self.current_course = None
        self.current_level = 1

        # 关卡类型定义（每门课程7个关卡）
        self.level_types = [
            "代码介绍",
            "实战填空 1",
            "实战填空 2",
            "实战填空 3",
            "实战填空 4",
            "程序实战 1",
            "程序实战 2"
        ]

        self.initUI()

    # ==================== 第四部分：数据加载和保存方法 ====================

    def load_checkin_data(self):
        """从JSON文件加载打卡数据"""
        if os.path.exists(self.checkin_file):
            try:
                with open(self.checkin_file, 'r', encoding='utf-8') as f:
                    return json.load(f)
            except:
                return {}
        return {}

    def save_checkin_data(self):
        """将打卡数据保存到JSON文件"""
        try:
            with open(self.checkin_file, 'w', encoding='utf-8') as f:
                json.dump(self.checkin_data, f, ensure_ascii=False, indent=2)
        except Exception as e:
            print(f"保存打卡数据失败: {e}")

    def load_currency_data(self):
        """从JSON文件加载货币数据 - 按用户ID隔离"""
        default_data = {'copper': 0, 'silver': 0, 'gold': 0}
        
        if os.path.exists(self.currency_file):
            try:
                with open(self.currency_file, 'r', encoding='utf-8') as f:
                    all_data = json.load(f)
                    # 按用户ID获取数据，如果不存在则返回默认值
                    user_id_str = str(self.current_user_id)
                    if user_id_str in all_data:
                        user_data = all_data[user_id_str]
                        # 确保数据完整性
                        if 'copper' not in user_data:
                            user_data['copper'] = 0
                        if 'silver' not in user_data:
                            user_data['silver'] = 0
                        if 'gold' not in user_data:
                            user_data['gold'] = 0
                        return user_data
                    return default_data.copy()
            except:
                return default_data.copy()
        return default_data.copy()

    def save_currency_data(self):
        """将货币数据保存到JSON文件 - 按用户ID隔离"""
        try:
            # 先读取所有用户的数据
            all_data = {}
            if os.path.exists(self.currency_file):
                with open(self.currency_file, 'r', encoding='utf-8') as f:
                    all_data = json.load(f)
            
            # 保存当前用户的数据
            user_id_str = str(self.current_user_id)
            all_data[user_id_str] = self.currency_data
            
            # 写入文件
            with open(self.currency_file, 'w', encoding='utf-8') as f:
                json.dump(all_data, f, ensure_ascii=False, indent=2)
        except Exception as e:
            print(f"保存货币数据失败: {e}")

    def load_learning_progress(self):
        """从JSON文件加载学习进度数据"""
        if os.path.exists(self.progress_file):
            try:
                with open(self.progress_file, 'r', encoding='utf-8') as f:
                    return json.load(f)
            except:
                return {}
        return {}

    def save_learning_progress(self):
        """将学习进度数据保存到JSON文件"""
        try:
            with open(self.progress_file, 'w', encoding='utf-8') as f:
                json.dump(self.learning_progress, f, ensure_ascii=False, indent=2)
        except Exception as e:
            print(f"保存学习进度失败: {e}")

    # ==================== 第五部分：学习进度管理方法 ====================

    def complete_level(self, course_name, level_num):
        """
        标记关卡为已完成
        功能：记录学习进度，奖励铜币，同步到数据库
        参数：
            course_name: 课程名称
            level_num: 关卡编号（1-7）
        返回：True表示新完成，False表示已存在
        """
        if course_name not in self.learning_progress:
            self.learning_progress[course_name] = []

        if level_num not in self.learning_progress[course_name]:
            self.learning_progress[course_name].append(level_num)
            self.learning_progress[course_name].sort()
            self.save_learning_progress()

            self.add_copper(5)

            from houtai_test import sync_daily_study_data
            sync_daily_study_data(self.current_user_id, 0, 0, 1)

            return True
        return False

    def is_level_completed(self, course_name, level_num):
        """检查指定关卡是否已完成"""
        if course_name in self.learning_progress:
            return level_num in self.learning_progress[course_name]
        return False

    def is_course_completed(self, course_name):
        """检查课程是否全部完成（7个关卡都完成）"""
        if course_name in self.learning_progress:
            return len(self.learning_progress[course_name]) >= 7
        return False

    # ==================== 第六部分：货币系统方法 ====================

    def add_copper(self, amount):
        """
        添加铜币并自动兑换成银币和金币
        兑换规则：100铜币=1银币，100银币=1金币
        参数：
            amount: 要添加的铜币数量
        """
        self.currency_data['copper'] += amount

        while self.currency_data['copper'] >= 100:
            self.currency_data['copper'] -= 100
            self.currency_data['silver'] += 1

        while self.currency_data['silver'] >= 100:
            self.currency_data['silver'] -= 100
            self.currency_data['gold'] += 1

        self.save_currency_data()
        self.update_currency_display()

    # ==================== 第七部分：打卡记录管理方法 ====================

    def remove_checkin_record(self, date_str):
        """
        删除指定日期的打卡记录，并奖励铜币
        参数：
            date_str: 日期字符串（格式：YYYY-MM-DD）
        返回：True表示删除成功，False表示记录不存在
        """
        if date_str in self.checkin_data:
            del self.checkin_data[date_str]
            self.save_checkin_data()
            self.add_copper(10)
            return True
        return False

    def remove_week_checkins(self):
        """删除最近一周的打卡记录，并奖励银币"""
        today = date.today()
        deleted_count = 0
        dates_to_delete = []

        for i in range(7):
            check_date = today - timedelta(days=i)
            date_str = check_date.strftime("%Y-%m-%d")
            if date_str in self.checkin_data:
                dates_to_delete.append(date_str)

        for date_str in dates_to_delete:
            del self.checkin_data[date_str]
            deleted_count += 1

        if deleted_count > 0:
            self.save_checkin_data()
            self.add_copper(deleted_count * 10 + (100 - deleted_count * 10))

        return deleted_count

    def remove_month_checkins(self):
        """删除最近一个月的打卡记录，并奖励金币"""
        today = date.today()
        deleted_count = 0
        dates_to_delete = []

        for i in range(30):
            check_date = today - timedelta(days=i)
            date_str = check_date.strftime("%Y-%m-%d")
            if date_str in self.checkin_data:
                dates_to_delete.append(date_str)

        for date_str in dates_to_delete:
            del self.checkin_data[date_str]
            deleted_count += 1

        if deleted_count > 0:
            self.save_checkin_data()
            self.add_copper(deleted_count * 10 + (1000 - deleted_count * 10))

        return deleted_count

    # ==================== 第八部分：界面初始化方法 ====================

