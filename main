    # ==================== 第十一部分：视图切换和数据更新 ====================

    def update_course_list_display(self):
        """更新课程列表显示，为已完成的课程添加绿色对勾标记"""
        for i in range(self.course_list.count()):
            item = self.course_list.item(i)
            course_name = item.text()

            # 移除旧的完成标记
            if " ✓" in course_name:
                course_name = course_name.replace(" ✓", "")

            # 如果课程已完成，添加绿色对勾
            if self.is_course_completed(course_name):
                item.setText(course_name + " ✓")
                item.setForeground(QColor(self.NATURE_GREEN))
            else:
                item.setText(course_name)
                item.setForeground(QColor(self.TEXT_PRIMARY))

    def switch_view(self, view_type):
        """
        切换视图模式
        参数：
            view_type: 'course'显示课程界面，'calendar'显示日历界面
        """
        if view_type == 'course':
            self.left_widget.setVisible(True)
            self.course_widget.setVisible(True)
            self.calendar_widget.setVisible(False)
            self.btn_course.setChecked(True)
            self.btn_calendar.setChecked(False)
        else:
            self.left_widget.setVisible(False)
            self.course_widget.setVisible(False)
            self.calendar_widget.setVisible(True)
            self.btn_course.setChecked(False)
            self.btn_calendar.setChecked(True)
            self.update_calendar()
            self.update_checkin_stats()

    # ==================== 第十二部分：日历功能方法 ====================

    def update_calendar(self):
        """更新日历显示 - 渲染当月所有日期，标记打卡状态"""
        year = self._current_year
        month = self._current_month

        self.current_month_label.setText(f"{year}年{month}月")

        first_day = date(year, month, 1)
        first_weekday = first_day.weekday()

        if month == 12:
            next_month = date(year + 1, 1, 1)
        else:
            next_month = date(year, month + 1, 1)
        days_in_month = (next_month - first_day).days

        # 清空网格中的所有控件
        while self.calendar_grid.count():
            item = self.calendar_grid.takeAt(0)
            widget = item.widget()
            if widget is not None:
                widget.deleteLater()

        # 添加星期标题（第0行）
        week_days = ["一", "二", "三", "四", "五", "六", "日"]
        for i, day_name in enumerate(week_days):
            label = QLabel(day_name)
            label.setAlignment(Qt.AlignCenter)
            label.setFont(QFont("Microsoft YaHei", 13, QFont.Bold))
            label.setStyleSheet(f"""
                QLabel {{
                    color: {self.NATURE_BLUE};
                    font-weight: bold;
                    padding: 8px;
                    font-size: 13px;
                }}
            """)
            self.calendar_grid.addWidget(label, 0, i)

        # 填充日期（从第1行开始）
        day = 1
        for row_idx in range(1, 7):
            for col_idx in range(7):
                if row_idx == 1 and col_idx < first_weekday:
                    continue
                if day > days_in_month:
                    break

                date_str = f"{year}-{month:02d}-{day:02d}"
                is_checked_in = date_str in self.checkin_data
                is_today = date(year, month, day) == date.today()

                btn = QPushButton(str(day))
                btn.setFont(QFont("Microsoft YaHei", 13))
                btn.setFixedSize(60, 60)
                btn.setProperty('is_day_button', True)
                btn.setProperty('day', day)
                btn.setProperty('year', year)
                btn.setProperty('month', month)

                if is_today:
                    if is_checked_in:
                        btn.setStyleSheet(f"""
                            QPushButton {{
                                background-color: {self.NATURE_GREEN};
                                color: #FFFFFF;
                                border: 3px solid {self.NATURE_CYAN};
                                border-radius: 8px;
                                font-size: 13px;
                                font-weight: bold;
                            }}
                            QPushButton:hover {{
                                background-color: #00C4A7;
                            }}
                        """)
                    else:
                        btn.setStyleSheet(f"""
                            QPushButton {{
                                background-color: {self.NATURE_RED};
                                color: #FFFFFF;
                                border: 3px solid {self.NATURE_ORANGE};
                                border-radius: 8px;
                                font-size: 13px;
                                font-weight: bold;
                            }}
                            QPushButton:hover {{
                                background-color: #D47A74;
                            }}
                        """)
                elif is_checked_in:
                    btn.setStyleSheet(f"""
                        QPushButton {{
                            background-color: {self.NATURE_GREEN};
                            color: #FFFFFF;
                            border: 2px solid {self.NATURE_CYAN};
                            border-radius: 8px;
                            font-size: 13px;
                        }}
                        QPushButton:hover {{
                            background-color: #00C4A7;
                        }}
                    """)
                else:
                    btn.setStyleSheet(f"""
                        QPushButton {{
                            background-color: {self.BG_MEDIUM};
                            color: {self.TEXT_PRIMARY};
                            border: 1px solid {self.BORDER_COLOR};
                            border-radius: 8px;
                            font-size: 13px;
                        }}
                        QPushButton:hover {{
                            background-color: {self.BG_LIGHT};
                            border: 2px solid {self.NATURE_CYAN};
                        }}
                    """)

                btn.clicked.connect(self.on_day_button_clicked)
                self.calendar_grid.addWidget(btn, row_idx, col_idx)

                day += 1

            if day > days_in_month:
                break

    def prev_month(self):
        """切换到上一个月"""
        if self._current_month == 1:
            self._current_year -= 1
            self._current_month = 12
        else:
            self._current_month -= 1
        self.update_calendar()

    def next_month(self):
        """切换到下一个月"""
        if self._current_month == 12:
            self._current_year += 1
            self._current_month = 1
        else:
            self._current_month += 1
        self.update_calendar()

    def on_day_button_clicked(self):
        """当用户点击日历中的某一天时触发 - 显示打卡信息"""
        btn = self.sender()
        day = btn.property('day')
        year = btn.property('year')
        month = btn.property('month')
        selected_date = date(year, month, day)
        date_str = selected_date.strftime("%Y-%m-%d")

        if date_str in self.checkin_data:
            checkin_time = self.checkin_data[date_str]["time"]
            QMessageBox.information(self, "打卡信息", f"✅ {date_str} 打卡成功！\n打卡时间: {checkin_time}")
        else:
            QMessageBox.information(self, "打卡信息", f"📍 {date_str} 尚未打卡")

    def show_study_plan(self):
        """显示今日智能学习计划 - 从后端数据库获取个性化计划"""
        from houtai_test import get_private_custom_study_plan
        plan_text = get_private_custom_study_plan(self.current_user_id)

        msg_box = QMessageBox()
        msg_box.setWindowTitle("今日智能学习计划")
        msg_box.setText(plan_text)
        msg_box.setFont(QFont("Microsoft YaHei", 10))
        msg_box.setStyleSheet("""
            QMessageBox {
                background-color: white;
            }
            QLabel {
                color: #1a3a52;
            }
        """)
        msg_box.exec_()

    def update_currency_display(self):
        """更新货币显示标签"""
        self.gold_label.setText(f"💰 金币: {self.currency_data['gold']}")
        self.silver_label.setText(f"🥈 银币: {self.currency_data['silver']}")
        self.copper_label.setText(f"🥉 铜币: {self.currency_data['copper']}")

    def get_selected_calendar_date(self):
        """获取日历中选中的日期（通过焦点判断）"""
        for i in range(self.calendar_grid.count()):
            item = self.calendar_grid.itemAt(i)
            if item:
                widget = item.widget()
                if isinstance(widget, QPushButton) and widget.property('is_day_button'):
                    if widget.isDown() or widget.hasFocus():
                        day = widget.property('day')
                        year = widget.property('year')
                        month = widget.property('month')
                        if day and year and month:
                            return date(year, month, day)
        return None

    # ==================== 第十三部分：打卡记录清除方法 ====================

    def clear_selected_day(self):
        """清除选中的日期打卡记录"""
        selected_date = self.get_selected_calendar_date()
        if not selected_date:
            QMessageBox.warning(self, "提示", "请先在日历中选择一个日期（点击日期按钮）！")
            return

        date_str = selected_date.strftime("%Y-%m-%d")
        if date_str not in self.checkin_data:
            QMessageBox.information(self, "提示", "该日期没有打卡记录！")
            return

        reply = QMessageBox.question(
            self,
            '确认清除',
            f'确定要清除 {date_str} 的打卡记录吗？\n\n奖励: 💰 10 铜币',
            QMessageBox.Yes | QMessageBox.No,
            QMessageBox.No
        )

        if reply == QMessageBox.Yes:
            if self.remove_checkin_record(date_str):
                QMessageBox.information(self, "成功", f"已清除 {date_str} 的打卡记录！\n获得奖励: 💰 10 铜币")
                self.update_calendar()
                self.update_checkin_stats()
                self.update_today_info()

    def clear_last_week(self):
        """清除最近一周的打卡记录"""
        today = date.today()
        week_ago = today - timedelta(days=6)

        delete_count = 0
        for i in range(7):
            check_date = today - timedelta(days=i)
            date_str = check_date.strftime("%Y-%m-%d")
            if date_str in self.checkin_data:
                delete_count += 1

        if delete_count == 0:
            QMessageBox.information(self, "提示", "最近一周没有打卡记录！")
            return

        reply = QMessageBox.question(
            self,
            '确认清除',
            f'确定要清除最近一周 ({week_ago.strftime("%m-%d")} ~ {today.strftime("%m-%d")}) 的打卡记录吗？\n共 {delete_count} 天有打卡记录\n\n奖励: 🥈 1 银币 (=100铜币)',
            QMessageBox.Yes | QMessageBox.No,
            QMessageBox.No
        )

        if reply == QMessageBox.Yes:
            deleted = self.remove_week_checkins()
            QMessageBox.information(self, "成功", f"已清除最近一周的 {deleted} 天打卡记录！\n获得奖励: 🥈 1 银币")
            self.update_calendar()
            self.update_checkin_stats()
            self.update_today_info()

    def clear_last_month(self):
        """清除最近一个月的打卡记录"""
        today = date.today()
        month_ago = today - timedelta(days=29)

        delete_count = 0
        for i in range(30):
            check_date = today - timedelta(days=i)
            date_str = check_date.strftime("%Y-%m-%d")
            if date_str in self.checkin_data:
                delete_count += 1

        if delete_count == 0:
            QMessageBox.information(self, "提示", "最近一个月没有打卡记录！")
            return

        reply = QMessageBox.question(
            self,
            '确认清除',
            f'确定要清除最近一个月 ({month_ago.strftime("%m-%d")} ~ {today.strftime("%m-%d")}) 的打卡记录吗？\n共 {delete_count} 天有打卡记录\n\n奖励: 💰 1 金币 (=1000铜币)',
            QMessageBox.Yes | QMessageBox.No,
            QMessageBox.No
        )

        if reply == QMessageBox.Yes:
            deleted = self.remove_month_checkins()
            QMessageBox.information(self, "成功", f"已清除最近一个月的 {deleted} 天打卡记录！\n获得奖励: 💰 1 金币")
            self.update_calendar()
            self.update_checkin_stats()
            self.update_today_info()

    # ==================== 第十四部分：打卡执行和统计方法 ====================

    def do_checkin(self):
        """执行今日打卡操作"""
        today_str = date.today().strftime("%Y-%m-%d")

        now = datetime.now()
        self.checkin_data[today_str] = {
            "date": today_str,
            "time": now.strftime("%H:%M:%S"),
            "timestamp": now.timestamp()
        }

        self.save_checkin_data()

        msg_box = QMessageBox()
        msg_box.setIcon(QMessageBox.Information)
        msg_box.setWindowTitle("打卡成功")
        msg_box.setText(f"✅ {today_str} 打卡成功！\n继续加油！")
        msg_box.exec_()

        self.update_calendar()
        self.update_checkin_stats()
        self.update_today_info()

    def update_checkin_stats(self):
        """更新打卡统计信息 - 总天数、最长连续、当前连续"""
        if not self.checkin_data:
            self.total_days_label.setText("总打卡天数: 0")
            self.continuous_days_label.setText("最长连续: 0 天")
            self.current_streak_label.setText("当前连续: 0 天")
            self.update_today_info()
            return

        total_days = len(self.checkin_data)
        self.total_days_label.setText(f"总打卡天数: {total_days}")

        dates = sorted([datetime.strptime(d, "%Y-%m-%d").date() for d in self.checkin_data.keys()])

        current_streak = 0
        today = date.today()
        check_date = today

        while check_date.strftime("%Y-%m-%d") in self.checkin_data:
            current_streak += 1
            check_date -= timedelta(days=1)

        self.current_streak_label.setText(f"当前连续: {current_streak} 天")

        max_streak = 0
        temp_streak = 1

        for i in range(1, len(dates)):
            if (dates[i] - dates[i - 1]).days == 1:
                temp_streak += 1
                max_streak = max(max_streak, temp_streak)
            else:
                temp_streak = 1

        if len(dates) > 0:
            max_streak = max(max_streak, 1)

        self.continuous_days_label.setText(f"最长连续: {max_streak} 天")

        self.update_today_info()

    def update_today_info(self):
        """更新今日打卡信息显示"""
        today_str = date.today().strftime("%Y-%m-%d")

        if today_str in self.checkin_data:
            checkin_time = self.checkin_data[today_str]["time"]
            self.today_info_label.setText(f"✅ 今日已打卡\n打卡时间: {checkin_time}")
            self.checkin_btn.setEnabled(True)
            self.checkin_btn.setText("✅ 再次打卡")
        else:
            self.today_info_label.setText(f"📍 今日还未打卡\n点击按钮完成打卡")
            self.checkin_btn.setEnabled(True)
            self.checkin_btn.setText("✅ 今日打卡")

    # ==================== 第十五部分：关卡内容管理方法 ====================

    def get_level_content(self, course_name, level_num):
        """
        获取指定课程的关卡内容
        参数：
            course_name: 课程名称
            level_num: 关卡编号（1-7）
        返回：包含标题、说明、代码、类型的字典
        """
        # 这里定义每个课程的关卡内容
        # 为了简洁，我只展示部分示例
        contents = {
            "Python 基础语法": {
                1: {
                    "title": "第1关：代码介绍 - Print函数",
                    "instruction": "学习使用print()函数输出内容。print()是Python中最基本的输出函数。",
                    "code": '# 使用print()函数输出内容\nprint("Hello, Python!")\nprint("欢迎来到编程世界")',
                    "type": "intro"
                },
                2: {
                    "title": "第2关：实战填空 - 输出姓名",
                    "instruction": "请在空白处填入正确的代码，使程序能够输出你的姓名。",
                    "code": '# 请在下面填入代码，输出你的姓名\n__________("我的姓名是：张三")',
                    "type": "fill",
                    "answer": "print"
                },
                3: {
                    "title": "第3关：实战填空 - 多行输出",
                    "instruction": "使用两个print语句，分别输出两行文字。",
                    "code": '# 输出第一行\nprint("第一行内容")\n# 输出第二行\n__________("第二行内容")',
                    "type": "fill",
                    "answer": "print"
                },
                4: {
                    "title": "第4关：实战填空 - 输出数字",
                    "instruction": "使用print输出数字100。",
                    "code": '# 输出数字100\nprint(____)',
                    "type": "fill",
                    "answer": "100"
                },
                5: {
                    "title": "第5关：实战填空 - 输出表达式",
                    "instruction": "使用print输出10+20的结果。",
                    "code": '# 输出10+20的结果\nprint(10 ____ 20)',
                    "type": "fill",
                    "answer": "+"
                },
                6: {
                    "title": "第6关：程序实战 - 个人信息卡片",
                    "instruction": "编写程序，输出一个包含姓名、年龄、城市的个人信息卡片。",
                    "code": '# 编写程序输出个人信息\n# 要求输出格式：\n# ========== \n# 姓名：张三\n# 年龄：20\n# 城市：北京\n# ==========\n\nprint("=" * 10)\nprint("姓名：张三")\nprint("年龄：20")\nprint("城市：北京")\nprint("=" * 10)',
                    "type": "practice"
                },
                7: {
                    "title": "第7关：程序实战 - 欢迎消息",
                    "instruction": "编写程序，输出一个欢迎消息，包含装饰线条。",
                    "code": '# 编写欢迎消息程序\n# 输出效果：\n# **************************\n#   欢迎来到Python学习！\n# **************************\n\nprint("*" * 26)\nprint("  欢迎来到Python学习！")\nprint("*" * 26)',
                    "type": "practice"
                }
            }
        }

        # 如果没有定义具体内容，返回默认内容
        if course_name not in contents:
            return {
                "title": f"第{level_num}关：{self.level_types[level_num - 1]}",
                "instruction": f"这是{course_name}的{self.level_types[level_num - 1]}关卡内容。",
                "code": f'# {course_name} - {self.level_types[level_num - 1]}\n# 请在此编写代码\nprint("Hello")',
                "type": "intro" if level_num == 1 else ("fill" if level_num <= 5 else "practice")
            }

        return contents[course_name].get(level_num, {
            "title": f"第{level_num}关",
            "instruction": "关卡内容加载中...",
            "code": "# 请编写代码",
            "type": "intro"
        })

    def on_course_selected(self, item):
        """当用户选择课程时触发 - 加载第一关内容"""
        course_name = item.text()

        # 移除完成标记
        if " ✓" in course_name:
            course_name = course_name.replace(" ✓", "")

        self.current_course = course_name
        self.current_level = 1

        # 加载第一关内容
        self.load_level()

        self.output_edit.setText(f"📖 已选择课程: {course_name}\n\n开始你的学习之旅吧！共有7个关卡等待你挑战。")

    def load_level(self):
        """加载当前关卡的内容到界面"""
        if not self.current_course:
            return

        content = self.get_level_content(self.current_course, self.current_level)

        # 更新关卡标题
        self.level_title_label.setText(content["title"])

        # 更新题目说明
        self.code_instruction.setText(content["instruction"])

        # 更新代码编辑器
        self.code_edit.setText(content["code"])

        # 更新关卡指示器
        self.update_level_indicators()

        # 更新关卡标签
        self.current_level_label.setText(f"第 {self.current_level} 关 / 共 7 关")

        # 更新按钮状态
        self.prev_level_btn.setEnabled(self.current_level > 1)
        self.next_level_btn.setEnabled(self.current_level < 7)

        # 清空输出
        self.output_edit.clear()

    def update_level_indicators(self):
        """更新关卡进度指示器 - 显示已完成、当前、未解锁状态"""
        for i in range(7):
            indicator = self.level_indicators[i]
            level_num = i + 1

            if self.is_level_completed(self.current_course, level_num):
                # 已完成 - 绿色对勾
                indicator.setText("✓")
                indicator.setStyleSheet(f"""
                    QLabel {{
                        background-color: {self.NATURE_GREEN};
                        color: #FFFFFF;
                        border: 2px solid {self.NATURE_CYAN};
                        border-radius: 17px;
                        font-weight: bold;
                    }}
                """)
            elif level_num == self.current_level:
                # 当前关卡 - 红色高亮
                indicator.setText(str(level_num))
                indicator.setStyleSheet(f"""
                    QLabel {{
                        background-color: {self.NATURE_RED};
                        color: #FFFFFF;
                        border: 3px solid {self.NATURE_ORANGE};
                        border-radius: 17px;
                        font-weight: bold;
                    }}
                """)
            else:
                # 未解锁 - 灰色
                indicator.setText(str(level_num))
                indicator.setStyleSheet(f"""
                    QLabel {{
                        background-color: {self.BG_MEDIUM};
                        color: {self.TEXT_SECONDARY};
                        border: 2px solid {self.BORDER_COLOR};
                        border-radius: 17px;
                    }}
                """)

    # ==================== 第十六部分：答案提交和代码运行 ====================

    def submit_answer(self):
        """提交答案 - 验证填空题或确认实践题完成"""
        if not self.current_course:
            QMessageBox.warning(self, "提示", "请先选择一个课程！")
            return

        content = self.get_level_content(self.current_course, self.current_level)

        if content["type"] == "fill":
            # 填空题类型 - 验证答案
            user_code = self.code_edit.toPlainText().strip()
            expected_answer = content.get("answer", "")

            if expected_answer and expected_answer in user_code:
                self.complete_level(self.current_course, self.current_level)

                msg_box = QMessageBox()
                msg_box.setIcon(QMessageBox.Information)
                msg_box.setWindowTitle("恭喜！")
                msg_box.setText(f"✅ 答案正确！\n\n获得奖励：💰 5 铜币")
                msg_box.exec_()

                self.update_level_indicators()
                self.update_course_list_display()

                if self.current_level < 7:
                    reply = QMessageBox.question(
                        self,
                        '继续学习',
                        '是否进入下一关？',
                        QMessageBox.Yes | QMessageBox.No,
                        QMessageBox.Yes
                    )
                    if reply == QMessageBox.Yes:
                        self.next_level()
            else:
                # 答案错误，记录到错题本
                from houtai_test import auto_save_wrong_item
                auto_save_wrong_item(
                    self.current_user_id,
                    content.get("title", ""),
                    user_code,
                    self.current_course.split()[0],
                    content.get("title", "")
                )
                QMessageBox.warning(self, "答案错误", "❌ 答案不正确，已记录到错题本！\n提示：仔细观察需要填空的位置。")
        else:
            # 实践题类型 - 先运行代码再确认完成
            self.run_code()

            reply = QMessageBox.question(
                self,
                '确认完成',
                '是否确认完成此关卡？（确保代码已正确编写并运行）',
                QMessageBox.Yes | QMessageBox.No,
                QMessageBox.Yes
            )

            if reply == QMessageBox.Yes:
                self.complete_level(self.current_course, self.current_level)

                msg_box = QMessageBox()
                msg_box.setIcon(QMessageBox.Information)
                msg_box.setWindowTitle("恭喜！")
                msg_box.setText(f"✅ 关卡完成！\n\n获得奖励：💰 5 铜币")
                msg_box.exec_()

                self.update_level_indicators()
                self.update_course_list_display()

                if self.is_course_completed(self.current_course):
                    QMessageBox.information(
                        self,
                        "课程完成！",
                        f"🎉 恭喜你完成了《{self.current_course}》的所有关卡！\n\n获得额外奖励：💰 50 铜币"
                    )
                    self.add_copper(50)

                if self.current_level < 7:
                    reply = QMessageBox.question(
                        self,
                        '继续学习',
                        '是否进入下一关？',
                        QMessageBox.Yes | QMessageBox.No,
                        QMessageBox.Yes
                    )
                    if reply == QMessageBox.Yes:
                        self.next_level()

    def next_level(self):
        """切换到下一关"""
        if self.current_level < 7:
            self.current_level += 1
            self.load_level()

    def prev_level(self):
        """切换到上一关"""
        if self.current_level > 1:
            self.current_level -= 1
            self.load_level()

    def run_code(self):
        """运行Python代码 - 使用exec执行并捕获输出"""
        code = self.code_edit.toPlainText()
        self.output_edit.clear()

        if not code.strip():
            self.output_edit.setText("⚠️ 警告: 代码为空，请输入代码后再运行。")
            return

        try:
            local_namespace = {}
            import io
            from contextlib import redirect_stdout

            f = io.StringIO()
            with redirect_stdout(f):
                exec(code, {}, local_namespace)

            out = f.getvalue()

            if out:
                self.output_edit.setText(f"✅ 运行成功:\n{out}")
            else:
                self.output_edit.setText("✅ 运行成功 (无输出)")

        except SyntaxError as e:
            self.output_edit.setText(f"❌ 语法错误:\n{str(e)}")
        except NameError as e:
            self.output_edit.setText(f"❌ 名称错误:\n{str(e)}")
        except TypeError as e:
            self.output_edit.setText(f"❌ 类型错误:\n{str(e)}")
        except Exception as e:
            self.output_edit.setText(f"❌ 运行时错误:\n{type(e).__name__}: {str(e)}")

    # ==================== 第十七部分：账号管理和窗口关闭 ====================

    def switch_account(self):
        """切换账号 - 退出当前账号并重新登录"""
        reply = QMessageBox.question(
            self,
            '切换账号',
            '确定要退出当前账号并重新登录吗？',
            QMessageBox.Yes | QMessageBox.No,
            QMessageBox.No
        )

        if reply == QMessageBox.Yes:
            # 先保存当前数据
            self.save_currency_data()
            self.save_learning_progress()

            # 创建新的登录对话框
            login_dialog = LoginDialog()
            if login_dialog.exec_() == QDialog.Accepted:
                user_id, username = login_dialog.get_user_info()

                # 创建新的主窗口
                new_window = CodeLearnWindow(user_id=user_id, username=username)
                new_window.show()

                # 设置标志位，关闭当前窗口时不触发确认对话框
                self._ignore_close_confirm = True
                self.close()

    def closeEvent(self, event):
        """窗口关闭事件"""
        self.save_currency_data()
        self.save_learning_progress()

        # 如果是切换账号，直接关闭不显示确认对话框
        if hasattr(self, '_ignore_close_confirm') and self._ignore_close_confirm:
            event.accept()
            return

        reply = QMessageBox.question(
            self,
            '确认退出',
            '确定要退出编程学习软件吗?',
            QMessageBox.Yes | QMessageBox.No,
            QMessageBox.No
        )

        if reply == QMessageBox.Yes:
            event.accept()
        else:
            event.ignore()


if __name__ == "__main__":
    app = QApplication(sys.argv)
    app.setStyle('Fusion')

    login_dialog = LoginDialog()
    if login_dialog.exec_() == QDialog.Accepted:
        user_id, username = login_dialog.get_user_info()
        window = CodeLearnWindow(user_id=user_id, username=username)
        window.show()
        sys.exit(app.exec_())
    else:
        sys.exit(0)
